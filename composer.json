{
  "name": "vergil-lai/wecom-aibot-php-sdk",
  "description": "企业微信智能机器人 PHP SDK - 基于 ReactPHP WebSocket 长连接",
  "keywords": [
    "企业微信",
    "智能机器人",
    "wecom",
    "wxwork",
    "bot",
    "aibot",
    "websocket"
  ],
  "author": "vergil-lai",
  "type": "library",
  "license": "MIT",
  "minimum-stability": "stable",
  "require": {
    "php": ">=8.1",
    "psr/log": "^2.0 || ^3.0",
    "react/event-loop": "^1.6",
    "react/promise": "^3.0",
    "react/socket": "^1.16",
    "react/http": "^1.10",
    "ratchet/pawl": "^0.4.3",
    "evenement/evenement": "^3.0"
  },
  "autoload": {
    "psr-4": {
      "VergilLai\\WecomAiBot\\": "src/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "friendsofphp/php-cs-fixer": "^3.50"
  }
}
